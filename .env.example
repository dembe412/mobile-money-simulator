# Mobile Money System - Environment Configuration

# Server Configuration
SERVER_ID=server_1
SERVER_NAME=Primary Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mobile_money_system
ECHO_SQL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Operation Configuration
LOCK_TIMEOUT=30
TRANSACTION_TIMEOUT=60
OPERATION_RETRY_COUNT=3
OPERATION_RETRY_DELAY=1000

# Replication Configuration (P2P Distributed)
REPLICATION_ENABLED=true
REPLICATION_INTERVAL=5
REPLICATION_TIMEOUT=10
REPLICATION_RETRY_COUNT=3
HEARTBEAT_INTERVAL=10
SYNC_INTERVAL=5
HASH_VIRTUAL_NODES=150
HASH_ALGORITHM=crc32

# Peer Servers (P2P Architecture - comma-separated URLs)
# Example for 3 servers: http://192.168.1.11:8001,http://192.168.1.12:8001,http://192.168.1.13:8001
# Each server should list OTHER servers (not itself)
PEER_SERVERS=http://localhost:8002,http://localhost:8003

# Security Configuration
REQUEST_SIGNING_KEY=your-secret-key-change-in-production
API_TOKEN_EXPIRY=3600
MAX_REQUEST_SIZE=10485760

# USSD Configuration
USSD_SESSION_TIMEOUT=180
USSD_REQUEST_TIMEOUT=60

# Notification Configuration
ASYNC_NOTIFICATION_ENABLED=true
RETRY_FAILED_NOTIFICATIONS=true
NOTIFICATION_RETRY_MAX=3
NOTIFICATION_BATCH_SIZE=100
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=

# Application Configuration
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
TIMEZONE=Africa/Nairobi
